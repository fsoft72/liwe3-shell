{
  "chrome-devtools": {
    "type": "stdio",
    "command": "npx",
    "args": [
      "chrome-devtools-mcp@latest"
    ],
    "env": {}
  },
  "svelte": {
    "type": "http",
    "url": "https://mcp.svelte.dev/mcp"
  },
  "gitnexus": {
    "command": "${GITNEXUS_BIN_PATH||gitnexus}",
    "args": [
      "mcp"
    ]
  },
  "codegraph": {
      "type": "stdio",
      "command": "codegraph",
      "args": ["serve", "--mcp"]
  },
  "cloudflare": {
      "url": "https://mcp.cloudflare.com/mcp"
  },
  "play-store": {
    "command": "uvx",
    "args": ["play-store-mcp"],
    "env": {
      "GOOGLE_APPLICATION_CREDENTIALS": "${GOOGLE_APPLICATION_CREDENTIALS}"
    }
  },
  "n8n": {
    "type": "http",
    "url": "${N8N_MCP_SERVER_URL}",
    "headers": {
      "Authorization": "Bearer ${N8N_MCP_API_KEY}"
    }
  }
}
